        {
          "datasource": {
            "type": "influxdb",
            "uid": "efn38cqkeercwa"
          },
          "query": "base = from(bucket: \"heater\")\r\n  |> range(start: -10m)\r\n  |> filter(fn: (r) => r._measurement == \"pool_heater\")\r\n  |> filter(fn: (r) => r._field == \"fault_codes\")\r\n\r\nfallback = base\r\n  |> last()\r\n  |> map(fn: (r) => ({ r with _value: \"No Fault\", priority: 0 }))\r\n\r\nfaults = base\r\n  |> filter(fn: (r) => r._value != \"\")\r\n  |> last()\r\n  |> map(fn: (r) => ({ r with priority: 1 }))\r\n\r\nunion(tables: [fallback, faults])\r\n  |> group(columns: [])\r\n  |> sort(columns: [\"priority\"])\r\n  |> last()\r\n  |> map(fn: (r) => ({ r with fault_code: r._value, _value: if r._value == \"No Fault\" then 0 else 1 }))\r\n  |> group(columns: [\"fault_code\"])\r\n  |> keep(columns: [\"_time\", \"_value\", \"fault_code\"])",
          "refId": "A"
        }
      ],
      "title": "Fault Status",
      "type": "stat"
